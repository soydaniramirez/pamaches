# ============================================================
# pamaches — variables de entorno (PLANTILLA)
# ============================================================
# Copia este archivo a `.env.local` y rellena los valores reales.
# `.env.local` está en .gitignore y NUNCA debe subirse al repositorio.
#
#   cp .env.example .env.local
#
# ------------------------------------------------------------
# Supabase — valores PÚBLICOS (se exponen al navegador)
# ------------------------------------------------------------
# La URL del proyecto y la "anon key" están diseñadas para usarse
# desde el cliente. Su seguridad NO depende de mantenerlas secretas,
# sino de las políticas RLS (Row Level Security) en la base de datos.
# Aun así las movemos a variables de entorno para no acoplarlas al código.
NEXT_PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key-aqui"

# ------------------------------------------------------------
# Supabase — valor SECRETO (solo servidor, NUNCA con prefijo NEXT_PUBLIC_)
# ------------------------------------------------------------
# La service role key salta TODAS las políticas RLS. Úsala únicamente en
# código de servidor (Route Handlers / Server Actions). Si no la necesitas
# todavía, déjala vacía. NUNCA la expongas al navegador.
SUPABASE_SERVICE_ROLE_KEY=""
